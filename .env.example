# Optional local environment variables for AI CLI workflows
# Copy to .env.local (or your preferred shell env file) and fill locally.
# Never commit real key values.

# Anthropic (used by Claude Code and zsh-ai when configured)
ANTHROPIC_API_KEY=

# OpenAI (used by Codex API-key mode or other tooling)
OPENAI_API_KEY=

# Optional: custom OpenAI-compatible endpoint for proxy/local gateways
# OPENAI_BASE_URL=
